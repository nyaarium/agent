ARG BASE_IMAGE=ghcr.io/nyaarium/workspace:latest
FROM ${BASE_IMAGE}

# Install Xvfb and X11 utilities for headless rendering
RUN apt update -qq && apt install -qq -y \
	xvfb \
	x11-utils \
	mesa-utils \
	x11-apps \
	&& apt clean && rm -rf /var/lib/apt/lists/*

# Install .NET SDK
RUN apt update -qq && apt install -qq -y libicu-dev \
	&& curl -fsSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh \
	&& chmod +x /tmp/dotnet-install.sh \
	&& /tmp/dotnet-install.sh --channel 8.0 --install-dir /usr/share/dotnet --no-path \
	&& ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet \
	&& rm /tmp/dotnet-install.sh \
	&& apt clean && rm -rf /var/lib/apt/lists/*

# Install Godot runtime dependencies
RUN apt update -qq && apt install -qq -y \
	libasound2t64 \
	libdbus-1-3 \
	libdecor-0-0 \
	libdrm2 \
	libegl1 \
	libfontconfig1 \
	libgbm1 \
	libgl1 \
	libglu1-mesa \
	libgtk-3-0 \
	libpulse0 \
	libudev1 \
	libwayland-client0 \
	libwayland-cursor0 \
	libwayland-egl1 \
	libx11-6 \
	libxcomposite1 \
	libxcursor1 \
	libxdamage1 \
	libxext6 \
	libxfixes3 \
	libxi6 \
	libxinerama1 \
	libxkbcommon0 \
	libxrandr2 \
	libxrender1 \
	libxss1 \
	libxtst6 \
	libxxf86vm1 \
	&& apt clean && rm -rf /var/lib/apt/lists/*

# Install Godot
ENV GODOT_VERSION="4.2.2"
RUN wget -nv -O /tmp/godot.zip https://github.com/godotengine/godot/releases/download/${GODOT_VERSION}-stable/Godot_v${GODOT_VERSION}-stable_linux.x86_64.zip \
	&& unzip -q /tmp/godot.zip -d /tmp \
	&& mv /tmp/Godot_v${GODOT_VERSION}-stable_linux.x86_64 /usr/local/bin/godot \
	&& chmod +x /usr/local/bin/godot \
	&& rm -rf /tmp/godot.zip

# Install Godot export templates to system location
RUN mkdir -p /var/lib/godot/templates/${GODOT_VERSION}.stable \
	&& wget -nv -O /tmp/godot-export-templates.tpz https://github.com/godotengine/godot/releases/download/${GODOT_VERSION}-stable/Godot_v${GODOT_VERSION}-stable_export_templates.tpz \
	&& unzip -q /tmp/godot-export-templates.tpz -d /var/lib/godot/templates/${GODOT_VERSION}.stable \
	&& rm /tmp/godot-export-templates.tpz
