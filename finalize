#!/bin/bash

# Stash agent user home for devcontainer compatibility
mkdir -p /var/home-seed
for item in /home/agent/.* /home/agent/*; do
    name=$(basename "$item")
    case "$name" in .|..|.bashrc|.bash_logout|.profile) continue ;; esac
    [ -e "$item" ] && cp -a "$item" /var/home-seed/
done

# Self-delete
rm -- "$0"
